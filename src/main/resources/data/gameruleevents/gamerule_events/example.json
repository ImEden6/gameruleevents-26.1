{
  "rules": [
    {
      "id": "daylight-off-notify",
      "gamerule": "minecraft:advance_time",
      "priority": 100,
      "cooldown_ticks": 40,
      "stop_after": true,
      "audience": "all",
      "when": { "any": true },
      "actions": [
        {
          "type": "broadcast_title",
          "title": { "translate": "gameruleevents.title.daylight_off" },
          "subtitle": { "text": "Time is frozen. {gamerule}: {old} -> {new}" },
          "fadeIn": 10,
          "stay": 40,
          "fadeOut": 10
        },
        {
          "type": "broadcast_sound",
          "sound": "minecraft:block.note_block.pling",
          "volume": 1.0,
          "pitch": 1.0
        },
        {
          "type": "broadcast_chat",
          "message": { "text": "[GameruleEvents] {gamerule} changed to {new}" }
        },
        {
          "type": "broadcast_actionbar",
          "message": { "text": "Rule changed: {gamerule}" }
        },
        {
          "type": "run_command",
          "as": "server",
          "command": "say doDaylightCycle is now {new}"
        }
      ]
    }
  ]
}

